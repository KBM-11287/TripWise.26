@model List<TripWise.Mvc.Models.TripViewModel>

<h2>Your Trips</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Destination</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var trip in Model)
        {
            <tr>
                <td>@trip.Title</td>
                <td>@trip.Destination</td>
                <td>@trip.StartDate.ToShortDateString()</td>
                <td>@trip.EndDate.ToShortDateString()</td>
                <td>
                    <a class="btn btn-primary" href="/Trips/Details/@trip.Id">View</a>
                </td>
            </tr>
        }
    </tbody>
</table>
